common --repository_cache=/Users/oren.ovadia/Library/Caches/bazel/repository_cache
build --disk_cache=/Users/oren.ovadia/Library/Caches/bazel/disk_cache
# Local disk cache — shared across all your worktrees & agents
common --disk_cache=~/.cache/bazel-disk

# Keep it bounded
common --experimental_disk_cache_gc_max_size=50G   # cap total size at 50 GiB
common --experimental_disk_cache_gc_max_age=7d     # evict entries older than 7 days
